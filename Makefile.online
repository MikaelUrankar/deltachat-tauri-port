# rsync /usr/ports/distfiles/deltachat-desktop-*-npm-cache.tar.gz freefall:public_distfiles/deltachat-desktop/

# XXX PORTNAME clash
PORTNAME=	deltachat-desktop
DISTVERSION=	2.43.0
CATEGORIES=	net-im
MASTER_SITES=	LOCAL/mikael/deltachat-tauri/:npm \
		https://github.com/${GH_ACCOUNT}/deltachat-desktop/archive/refs/tags/
DISTFILES=	v${DISTVERSION}.tar.gz \
#                deltachat-tauri-${DISTVERSION}-npm-cache.tar.gz:npm

MAINTAINER=	mikael@FreeBSD.org
COMMENT=	Cross-platform decentralized encrypted messaging service
WWW=		https://delta.chat/

LICENSE=	AGPLv3
LICENSE_FILE=	${WRKSRC}/LICENSE

LIB_DEPENDS=	libdbus-1.so:devel/dbus \
		libsoup-3.0.so:devel/libsoup3 \
		libwebkit2gtk-4.1.so:www/webkit2-gtk@41

USES=		cargo gmake nodejs:22,build pkgconfig ssl
USE_GNOME+=	cairo gdkpixbuf glib20 gtk30

GH_ACCOUNT=	deltachat

CONFLICTS_BUILD=devel/esbuild

MAKE_ENV+=	PATH=${WRKSRC}/node_modules/.bin:${WRKSRC}/pnpmbin/node_modules/.bin:${LOCALBASE}/bin:${PATH}

# XXX
CARGO_ENV+=	VERSION_INFO_GIT_REF=c4de177bdf50846ea06b5e0074ec4f7eafe609a0

post-patch:
	${REINPLACE_CMD} "s|${PREFIX}|${PREFIX}|" \
		${WRKSRC}/cargo-crates/tauri-utils-2.8.1/src/platform.rs

	${ECHO_CMD} store-dir=true >> ${WRKSRC}/.pnpm-store

