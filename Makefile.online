# make -f Makefile.online
# cp -f work/deltachat-desktop-*/pnpm-lock.yaml files
# rm /usr/ports/distfiles/deltachat-desktop-*-npm-cache.tar.gz
# make -f Makefile.online create-caches-tarball
# cp work/deltachat-desktop-*-npm-cache.tar.gz /usr/ports/distfiles/
# meld Makefile.online Makefile
