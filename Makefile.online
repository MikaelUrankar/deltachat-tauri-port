#	cd ${WRKSRC} && \
#		${SETENV} ${MAKE_ENV} pnpm translations:convert

do-install:
	${INSTALL_PROGRAM} ${CARGO_TARGET_DIR}/*/deltachat-tauri ${STAGEDIR}${LOCALBASE}/bin

	# see files/patch-tauri-utils
	${MKDIR} ${STAGEDIR}/${LOCALBASE}/lib/deltachat-tauri/_locales
	cd ${WRKSRC}/_locales && \
		${COPYTREE_SHARE} . ${STAGEDIR}/${LOCALBASE}/lib/deltachat-tauri/_locales

create-caches-tarball:
	# do some cleanup first
	${RM} -r ${WRKDIR}/.npm/_logs ${WRKDIR}/.npm/_update-notifier-last-checked

	cd ${WRKDIR} && \
		${TAR} czf deltachat-desktop-${DISTVERSION}-npm-cache.tar.gz .npm pnpm .cache


.include <bsd.port.mk>
